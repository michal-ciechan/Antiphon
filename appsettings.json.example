{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=antiphon;Username=antiphon;Password=antiphon_dev"
  },
  "Git": {
    "WorkspacePath": "",
    "DefaultBranch": "main",
    "PollIntervalSeconds": 30,
    "WorktreeBasePath": "/tmp/antiphon-worktrees",
    "WorktreeStaleAfterDays": 7,
    "WorktreeJanitorIntervalHours": 24
  },
  "Llm": {
    "DefaultProvider": "anthropic",
    "DefaultModel": "",
    "Providers": [
      {
        "Name": "anthropic",
        "ApiKey": "<your-api-key>",
        "BaseUrl": "https://api.anthropic.com",
        "Models": ["claude-sonnet-4-20250514"]
      },
      {
        "Name": "openai",
        "ApiKey": "<your-api-key>",
        "BaseUrl": "https://api.openai.com",
        "Models": ["gpt-4o"]
      }
    ]
  },
  "SignalR": {
    "HubPath": "/hubs/workflow",
    "ReconnectIntervalsMs": [0, 2000, 5000, 10000, 30000],
    "KeepAliveIntervalSeconds": 15,
    "ClientTimeoutSeconds": 30
  },
  "Audit": {
    "RetentionDays": 90,
    "EnableFullContent": true,
    "EnableIpLogging": true
  },
  "GitHub": {
    "Enabled": false,
    "PersonalAccessToken": "<your-pat>",
    "BaseUrl": "https://api.github.com"
  },
  "Agents": {
    "DefaultDefinition": "claude",
    "Definitions": {
      "claude": {
        "Kind": "ClaudeCode",
        "Exe": "cl.bat",
        "ArgsTemplate": [],
        "Env": {}
      },
      "codex": {
        "Kind": "Codex",
        "Exe": "pwsh.exe",
        "ArgsTemplate": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "C:\\Users\\<you>\\.local\\bin\\cx.ps1", "--no-alt-screen"],
        "Env": {}
      },
      "raw-pwsh": {
        "Kind": "Raw",
        "Exe": "pwsh.exe",
        "ArgsTemplate": ["-NoLogo", "-NoProfile"],
        "Env": {}
      }
    },
    "ClaudeReadyQuietPeriodMs": 5000,
    "ClaudeReadyMaxWaitMs": 60000,
    "ClaudeDoneMaxWaitMs": 300000,
    "CodexReadyQuietPeriodMs": 1000,
    "CodexReadyMaxWaitMs": 60000,
    "CodexDoneQuietPeriodMs": 3000,
    "CodexDoneMaxWaitMs": 300000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
