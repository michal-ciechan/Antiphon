{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=17280;Database=antiphon;Username=antiphon;Password=antiphon_dev"
  },
  "Git": {
    "WorkspacePath": "D:\\src\\Antiphon\\workspace",
    "DefaultBranch": "main",
    "PollIntervalSeconds": 30,
    "WorktreeBasePath": "C:\\Antiphon\\worktrees",
    "WorktreeStaleAfterDays": 7,
    "WorktreeJanitorIntervalHours": 24
  },
  "Llm": {
    "DefaultProvider": "openai",
    "DefaultModel": "claude-sonnet-4-6",
    "Providers": {
      "openai": {
        "ApiKey": "",
        "BaseUrl": "https://api.openai.com",
        "Models": ["gpt-5.2", "gpt-4o", "gpt-4o-mini", "o3", "o4-mini"]
      },
      "anthropic": {
        "ApiKey": "",
        "BaseUrl": "https://api.anthropic.com",
        "Models": ["claude-opus-4-6", "claude-sonnet-4-6", "claude-haiku-4-5-20251001"]
      }
    }
  },
  "SignalR": {
    "HubPath": "/hubs/workflow",
    "ReconnectIntervalsMs": [0, 2000, 5000, 10000, 30000],
    "KeepAliveIntervalSeconds": 15,
    "ClientTimeoutSeconds": 30
  },
  "Audit": {
    "RetentionDays": 90,
    "EnableFullContent": true,
    "EnableIpLogging": true
  },
  "GitHub": {
    "Enabled": false,
    "PersonalAccessToken": "",
    "BaseUrl": "https://api.github.com"
  },
  "SessionRunner": {
    "BaseUrl": "http://localhost:17283",
    "Enabled": true,
    "EventReconnectDelayMs": 1000
  },
  "Agents": {
    "DefaultDefinition": "claude",
    "Definitions": {
      "claude": {
        "Kind": "ClaudeCode",
        "Exe": "claude.exe",
        "ArgsTemplate": ["--dangerously-skip-permissions"],
        "Env": {}
      },
      "codex": {
        "Kind": "Codex",
        "Exe": "pwsh.exe",
        "ArgsTemplate": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command", "cx.ps1 --no-alt-screen --dangerously-bypass-approvals-and-sandbox"],
        "Env": {}
      },
      "raw-pwsh": {
        "Kind": "Raw",
        "Exe": "pwsh.exe",
        "ArgsTemplate": ["-NoLogo", "-NoProfile"],
        "Env": {}
      }
    },
    "ClaudeReadyQuietPeriodMs": 5000,
    "ClaudeReadyMaxWaitMs": 60000,
    "ClaudeDoneMaxWaitMs": 300000,
    "CodexReadyQuietPeriodMs": 1000,
    "CodexReadyMaxWaitMs": 60000,
    "CodexDoneQuietPeriodMs": 3000,
    "CodexDoneMaxWaitMs": 300000
  },
  "AgentSessions": {
    "SessionLogPath": "logs/sessions"
  },
  "SessionReconciliation": {
    "Enabled": true,
    "IntervalMs": 15000,
    "StartingGraceMs": 90000,
    "AgentGraceMs": 120000
  },
  "ChannelBridge": {
    "Enabled": false,
    "AgentStartTimeoutSeconds": 90,
    "AgentReadyDelaySeconds": 12,
    "MaxReplyChars": 4000,
    "PendingReplyTtlMinutes": 30
  },
  "AntiphonMessaging": {
    "BootstrapServers": "localhost:19092",
    "InboundTopic": "channels.inbound",
    "OutboundTopic": "channels.outbound",
    "ConsumerGroup": "antiphon-server-bridge"
  },
  "Serilog": {
    "LogPath": "logs"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
