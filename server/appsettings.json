{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=antiphon;Username=antiphon;Password=antiphon_dev"
  },
  "Git": {
    "WorkspacePath": "D:\\src\\Antiphon\\workspace",
    "DefaultBranch": "main",
    "PollIntervalSeconds": 30,
    "WorktreeBasePath": "/tmp/antiphon-worktrees"
  },
  "Llm": {
    "DefaultProvider": "openai",
    "DefaultModel": "claude-sonnet-4-6",
    "Providers": {
      "openai": {
        "ApiKey": "",
        "BaseUrl": "https://api.openai.com",
        "Models": ["gpt-5.2", "gpt-4o", "gpt-4o-mini", "o3", "o4-mini"]
      },
      "anthropic": {
        "ApiKey": "",
        "BaseUrl": "https://api.anthropic.com",
        "Models": ["claude-opus-4-6", "claude-sonnet-4-6", "claude-haiku-4-5-20251001"]
      }
    }
  },
  "SignalR": {
    "HubPath": "/hubs/workflow",
    "ReconnectIntervalsMs": [0, 2000, 5000, 10000, 30000],
    "KeepAliveIntervalSeconds": 15,
    "ClientTimeoutSeconds": 30
  },
  "Audit": {
    "RetentionDays": 90,
    "EnableFullContent": true,
    "EnableIpLogging": true
  },
  "GitHub": {
    "Enabled": false,
    "PersonalAccessToken": "",
    "BaseUrl": "https://api.github.com"
  },
  "Serilog": {
    "LogPath": "logs"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
